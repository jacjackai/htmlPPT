<!DOCTYPE html>
<html lang="zh-CN">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>演示模式增强版</title>
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
	<link rel="stylesheet" href="css/styles.css">
</head>
<body>
	<div class="container">
		<div class="sidebar" id="sidebar">
			<div class="sidebar-header">
				<h2>htmlPPT</h2>
				<button class="toggle-sidebar tooltip" id="toggleSidebar" data-tooltip="切换侧边栏">
					<i class="fas fa-chevron-left"></i>
				</button>
			</div>
			<button class="add-slide-btn" id="addSlide">
				<i class="fas fa-plus"></i>
				<span>新建幻灯片</span>
			</button>
			<div class="slides-list" id="slidesList">
			</div>
		</div>

		<div class="main-content" id="mainContent">
			<div class="header">
				<h2 id="editable-title" contenteditable="true" spellcheck="false" lang="zh-CN" data-placeholder="输入标题">HTML PPT</h2>
				<div class="header-buttons">
					<button class="header-btn auto-save-btn on tooltip" id="autoSaveToggle" data-tooltip="自动保存">
						<i class="fas fa-toggle-on"></i>
					</button>
					<button class="header-btn undo-btn tooltip" id="undoBtn" data-tooltip="撤销 (Ctrl+Z)">
						<i class="fas fa-undo"></i> 撤销
					</button>
					<button class="header-btn redo-btn tooltip" id="redoBtn" data-tooltip="重做 (Ctrl+Y)">
						<i class="fas fa-redo"></i> 重做
					</button>

<div class="file-dropdown" id="fileDropdown">
							<button class="header-btn file-selector-btn tooltip" id="fileSelectorBtn" data-tooltip="文件操作">
								<i class="fas fa-file"></i> 文件
								<i class="fas fa-chevron-down dropdown-arrow"></i>
							</button>
							<div class="file-dropdown-content">
								<div class="file-option" id="fileNew" data-tooltip="新建项目 (Ctrl+N)">
									<i class="fas fa-file"></i> 新建
								</div>
								<div class="file-option" id="fileOpen" data-tooltip="打开项目 (Ctrl+O)">
								<i class="fas fa-chevron-down dropdown-arrow"></i>
							</button>
							<div class="file-dropdown-content">
								<div class="file-option" id="fileNew" data-tooltip="新建项目 (Ctrl+N)">
									<i class="fas fa-file"></i> 新建
								</div>
								<div class="file-option" id="fileOpen" data-tooltip="打开项目 (Ctrl+O)">
									<i class="fas fa-folder-open"></i> 打开
								</div>
								<div class="file-option" id="fileSave" data-tooltip="保存项目 (Ctrl+S)">
									<i class="fas fa-save"></i> 保存
								</div>
							</div>
						</div>
<div class="file-dropdown" id="fileDropdown">
							<button class="header-btn file-selector-btn tooltip" id="fileSelectorBtn" data-tooltip="文件操作">
								<i class="fas fa-file"></i> 文件
								<i class="fas fa-chevron-down dropdown-arrow"></i>
							</button>
							<div class="file-dropdown-content">
								<div class="file-option" id="fileNew" data-tooltip="新建项目 (Ctrl+N)">
									<i class="fas fa-file"></i> 新建
								</div>
								<div class="file-option" id="fileOpen" data-tooltip="打开项目 (Ctrl+O)">
									<i class="fas fa-folder-open"></i> 打开
								</div>
								<div class="file-option" id="fileSave" data-tooltip="保存项目 (Ctrl+S)">
									<i class="fas fa-save"></i> 保存
								</div>
							</div>
						</div>
<div class="file-dropdown" id="fileDropdown">
							<button class="header-btn file-selector-btn tooltip" id="fileSelectorBtn" data-tooltip="文件操作">
								<i class="fas fa-file"></i> 文件
								<i class="fas fa-chevron-down dropdown-arrow"></i>
							</button>
							<div class="file-dropdown-content">
								<div class="file-option" id="fileNew" data-tooltip="新建项目 (Ctrl+N)">
									<i class="fas fa-file"></i> 新建
								</div>
								<div class="file-option" id="fileOpen" data-tooltip="打开项目 (Ctrl+O)">
									<i class="fas fa-folder-open"></i> 打开
								</div>
								<div class="file-option" id="fileSave" data-tooltip="保存项目 (Ctrl+S)">
									<i class="fas fa-save"></i> 保存
								</div>
							</div>
						</div>
<div class="file-dropdown" id="fileDropdown">
							<button class="header-btn file-selector-btn tooltip" id="fileSelectorBtn" data-tooltip="文件操作">
								<i class="fas fa-file"></i> 文件
								<i class="fas fa-chevron-down dropdown-arrow"></i>
							</button>
							<div class="file-dropdown-content">
								<div class="file-option" id="fileNew" data-tooltip="新建项目 (Ctrl+N)">
									<i class="fas fa-file"></i> 新建
								</div>
								<div class="file-option" id="fileOpen" data-tooltip="打开项目 (Ctrl+O)">
									<i class="fas fa-folder-open"></i> 打开
								</div>
								<div class="file-option" id="fileSave" data-tooltip="保存项目 (Ctrl+S)">
									<i class="fas fa-save"></i> 保存
								</div>
							</div>
						</div>
<div class="file-dropdown" id="fileDropdown">
							<button class="header-btn file-selector-btn tooltip" id="fileSelectorBtn" data-tooltip="文件操作">
								<i class="fas fa-file"></i> 文件
								<i class="fas fa-chevron-down dropdown-arrow"></i>
							</button>
							<div class="file-dropdown-content">
								<div class="file-option" id="fileNew" data-tooltip="新建项目 (Ctrl+N)">
									<i class="fas fa-file"></i> 新建
								</div>
								<div class="file-option" id="fileOpen" data-tooltip="打开项目 (Ctrl+O)">
									<i class="fas fa-folder-open"></i> 打开
								</div>
								<div class="file-option" id="fileSave" data-tooltip="保存项目 (Ctrl+S)">
									<i class="fas fa-save"></i> 保存
								</div>
							</div>
						</div>
<div class="file-dropdown" id="fileDropdown">
							<button class="header-btn file-selector-btn tooltip" id="fileSelectorBtn" data-tooltip="文件操作">
								<i class="fas fa-file"></i> 文件
								<i class="fas fa-chevron-down dropdown-arrow"></i>
							</button>
							<div class="file-dropdown-content">
								<div class="file-option" id="fileNew" data-tooltip="新建项目 (Ctrl+N)">
									<i class="fas fa-file"></i> 新建
								</div>
								<div class="file-option" id="fileOpen" data-tooltip="打开项目 (Ctrl+O)">
									<i class="fas fa-folder-open"></i> 打开
								</div>
								<div class="file-option" id="fileSave" data-tooltip="保存项目 (Ctrl+S)">
									<i class="fas fa-save"></i> 保存
								</div>
							</div>
						</div>
<div class="file-dropdown" id="fileDropdown">
							<button class="header-btn file-selector-btn tooltip" id="fileSelectorBtn" data-tooltip="文件操作">
								<i class="fas fa-file"></i> 文件
								<i class="fas fa-chevron-down dropdown-arrow"></i>
							</button>
							<div class="file-dropdown-content">
								<div class="file-option" id="fileNew" data-tooltip="新建项目 (Ctrl+N)">
									<i class="fas fa-file"></i> 新建
								</div>
								<div class="file-option" id="fileOpen" data-tooltip="打开项目 (Ctrl+O)">
									<i class="fas fa-folder-open"></i> 打开
								</div>
								<div class="file-option" id="fileSave" data-tooltip="保存项目 (Ctrl+S)">
									<i class="fas fa-save"></i> 保存
								</div>
							</div>
						</div>
					</button>
					<button class="header-btn present-btn tooltip" id="presentBtn" data-tooltip="演示模式">
						<i class="fas fa-play"></i> 演示模式
					</button>
					<div class="theme-dropdown" id="themeDropdown">
						<button class="header-btn theme-selector-btn tooltip" id="themeSelectorBtn" data-tooltip="选择主题">
							<i class="fas fa-palette"></i> 主题
							<i class="fas fa-chevron-down dropdown-arrow"></i>
						</button>
						<div class="theme-dropdown-content">
							<div class="theme-option" data-theme="light">浅色</div>
							<div class="theme-option" data-theme="dark">深色</div>
							<div class="theme-option" data-theme="business">商业</div>
							<div class="theme-option" data-theme="creative">创意</div>
							<div class="theme-option" data-theme="minimal">极简</div>
							<div class="theme-option" data-theme="ocean">海洋</div>
							<div class="theme-option" data-theme="forest">森林</div>
							<div class="theme-option" data-theme="sunset">日落</div>
						</div>
					</div>
				</div>
			</div>

			<div class="editor-container">
				<div class="preview" id="previewPanel">
					<div class="panel-header">
						<span>PPT</span>
					</div>
					<div class="preview-area" id="previewArea" contenteditable="true"></div>
				</div>

				<div class="resizer" id="resizer"></div>

				<div class="code-editor" id="codeEditorPanel">
					<div class="panel-header">
						<span>HTML</span>
					</div>
					<textarea class="code-area" id="codeEditor" placeholder="在此处编写HTML代码..."></textarea>
				</div>
			</div>
		</div>
	</div>



	<div class="presentation-mode" id="presentationMode">
		<div class="slide-container">
			<iframe class="presentation-slide" id="presentationSlide"></iframe>
		</div>
		<div class="presentation-hint" id="presentationHint">
			使用 ← → 方向键切换幻灯片，按 ESC 键退出演示模式
		</div>
		<div class="presentation-controls" id="presentationControls">
			<button id="prevSlideBtn"><i class="fas fa-arrow-left"></i></button>
			<div class="slide-counter"><span id="currentSlideNum">1</span> / <span id="totalSlides">1</span></div>
			<button id="nextSlideBtn"><i class="fas fa-arrow-right"></i></button>
			<button id="sharePresentationBtn"><i class="fas fa-share-alt"></i></button>
		</div>
	</div>

	<div class="notification" id="notification">
		<i class="fas fa-check-circle"></i>
		<span>操作成功！</span>
	</div>

	<input type="file" id="fileInput" class="file-input" accept=".htmlppt,.json">

	<div class="auto-save-indicator" id="autoSaveIndicator">
		<div class="spinner"></div>
		<span>自动保存中...</span>
	</div>

	<div class="modal" id="shareModal">
		<div class="modal-content share-modal">
			<div class="modal-header">
				<h2>分享演示</h2>
				<button class="close-modal" id="closeShareModal">&times;</button>
			</div>
			<div class="modal-body">
				<p>复制以下链接分享您的演示文稿：</p>
				<input type="text" id="shareLink" readonly>
				<button class="copy-btn" id="copyShareLink">复制链接</button>
			</div>
			<div class="modal-footer">
				<button class="modal-btn modal-btn-secondary" id="cancelShare">关闭</button>
			</div>
		</div>
	</div>

	<div class="modal" id="themeModal">
		<div class="modal-content theme-modal">
			<div class="modal-header">
				<h2>选择主题</h2>
				<button class="close-modal" id="closeThemeModal">&times;</button>
			</div>
			<div class="modal-body">
				<div class="theme-options">
					<div class="theme-option" data-theme="light">
						<div class="theme-preview light-preview"></div>
						<span>浅色</span>
					</div>
					<div class="theme-option" data-theme="dark">
						<div class="theme-preview dark-preview"></div>
						<span>深色</span>
					</div>
					<div class="theme-option" data-theme="business">
						<div class="theme-preview business-preview"></div>
						<span>商业</span>
					</div>
					<div class="theme-option" data-theme="creative">
						<div class="theme-preview creative-preview"></div>
						<span>创意</span>
					</div>
					<div class="theme-option" data-theme="minimal">
						<div class="theme-preview minimal-preview"></div>
						<span>极简</span>
					</div>
					<div class="theme-option" data-theme="ocean">
						<div class="theme-preview ocean-preview"></div>
						<span>海洋</span>
					</div>
					<div class="theme-option" data-theme="forest">
						<div class="theme-preview forest-preview"></div>
						<span>森林</span>
					</div>
					<div class="theme-option" data-theme="sunset">
						<div class="theme-preview sunset-preview"></div>
						<span>日落</span>
					</div>
				</div>
			</div>
			<div class="modal-footer">
				<button class="modal-btn modal-btn-secondary" id="cancelTheme">关闭</button>
			</div>
		</div>
	</div>

	<script type="module" src="js/app-entry.js"></script>
</body>
</html>
